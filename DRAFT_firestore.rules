rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validator: User
    function isValidUser(data, userId) {
      return data.userId == userId &&
             data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 512)) &&
             data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    // Entity validator: CustomBook
    function isValidCustomBook(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.author is string && data.author.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.rating is number &&
             data.reviewsCount is number &&
             data.duration is string && data.duration.size() <= 50 &&
             data.pages is number &&
             data.coverColor is string && data.coverColor.size() <= 50 &&
             data.synopsis is string && data.synopsis.size() <= 2000 &&
             (!data.keys().contains('buyUrl') || (data.buyUrl is string && data.buyUrl.size() <= 512)) &&
             data.isCustom == true &&
             data.createdBy == request.auth.uid;
    }

    // Entity validator: ReadingListItem
    function isValidReadingListItem(data) {
      return (data.bookId is string || data.bookId is number) &&
             data.progressStatus is string && (
               data.progressStatus == 'ingin_dibaca' || 
               data.progressStatus == 'sedang_dibaca' || 
               data.progressStatus == 'selesai'
             ) &&
             (!data.keys().contains('notes') || (data.notes is string && data.notes.size() <= 2000)) &&
             data.savedAt is string && data.savedAt.size() <= 64 &&
             data.userId == request.auth.uid;
    }

    // Entity validator: UserNote
    function isValidUserNote(data) {
      return data.text is string && data.text.size() <= 10000 &&
             data.updatedAt is string && data.updatedAt.size() <= 64 &&
             data.userId == request.auth.uid;
    }

    // Entity validator: Review
    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128 &&
             (data.bookId is string || data.bookId is number) &&
             data.reviewerName is string && data.reviewerName.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt is string && data.createdAt.size() <= 64 &&
             data.userId == request.auth.uid;
    }

    // USERS COLLECTION & SUB-COLLECTIONS
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data, userId);
      allow update: if isOwner(userId) && isValidUser(request.resource.data, userId) && 
                      request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Profiles are permanent once signed-up

      // Nested custom books
      match /books/{bookId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(bookId) && isValidCustomBook(request.resource.data);
        allow update: if isOwner(userId) && isValidId(bookId) && isValidCustomBook(request.resource.data) &&
                        request.resource.data.createdBy == resource.data.createdBy &&
                        request.resource.data.id == resource.data.id;
        allow delete: if isOwner(userId) && isValidId(bookId);
      }

      // Nested reading list progress
      match /readingList/{bookId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReadingListItem(request.resource.data);
        allow update: if isOwner(userId) && isValidReadingListItem(request.resource.data) &&
                        request.resource.data.bookId == resource.data.bookId;
        allow delete: if isOwner(userId);
      }

      // Nested notepad notes
      match /notes/{noteId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(noteId) && isValidUserNote(request.resource.data);
        allow update: if isOwner(userId) && isValidId(noteId) && isValidUserNote(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(noteId);
      }
    }

    // GLOBAL REVIEWS COLLECTION
    match /reviews/{reviewId} {
      allow read, list: if true; // Publicly readable reviews
      allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(request.resource.data);
      allow update: if isSignedIn() && isValidId(reviewId) && 
                      resource.data.userId == request.auth.uid && 
                      isValidReview(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.bookId == resource.data.bookId;
      allow delete: if isSignedIn() && isValidId(reviewId) && resource.data.userId == request.auth.uid;
    }
  }
}
