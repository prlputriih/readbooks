{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with information synchronized upon auth registration",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Unik ID milik user"
        },
        "displayName": {
          "type": "string",
          "description": "Nama tampilan pengguna"
        },
        "email": {
          "type": "string",
          "description": "Email address of the authenticated user"
        },
        "photoURL": {
          "type": "string",
          "description": "Optional profile photo URL of the user"
        },
        "updatedAt": {
          "type": "string",
          "description": "Tanggal profil terakhir diperbarui"
        }
      },
      "required": ["userId", "displayName"]
    },
    "Book": {
      "title": "Book",
      "description": "Custom book added by a user to their catalog",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identifier key for the book"
        },
        "title": {
          "type": "string",
          "description": "Judul buku"
        },
        "author": {
          "type": "string",
          "description": "Penulis buku"
        },
        "category": {
          "type": "string",
          "description": "Kategori atau genre buku"
        },
        "rating": {
          "type": "number",
          "description": "Rating buku"
        },
        "reviewsCount": {
          "type": "number",
          "description": "Jumlah total ulasan"
        },
        "reviews": {
          "type": "array",
          "description": "Nested reviews inline arrays"
        },
        "duration": {
          "type": "string",
          "description": "Perkiraan durasi waktu baca"
        },
        "pages": {
          "type": "number",
          "description": "Jumlah halaman"
        },
        "coverColor": {
          "type": "string",
          "description": "Utility warna cover Tailwind"
        },
        "synopsis": {
          "type": "string",
          "description": "Ringkasan sinopsis cerita"
        },
        "buyUrl": {
          "type": "string",
          "description": "Tautan opsional pembelian buku"
        },
        "createdBy": {
          "type": "string",
          "description": "ID pengguna pembuat buku"
        },
        "createdAt": {
          "type": "string",
          "description": "Waktu pembuatan data buku"
        }
      },
      "required": ["id", "title", "author", "category"]
    },
    "ReadingListItem": {
      "title": "ReadingListItem",
      "description": "Tracks bookmarks and progress status of reading books",
      "type": "object",
      "properties": {
        "bookId": {
          "type": "string",
          "description": "ID of reference book"
        },
        "progressStatus": {
          "type": "string",
          "enum": ["ingin_dibaca", "sedang_dibaca", "selesai"],
          "description": "Status progres membaca"
        },
        "notes": {
          "type": "string",
          "description": "User specific personal book notes"
        },
        "savedAt": {
          "type": "string",
          "description": "Timestamp data bookmark ditambahkan"
        },
        "userId": {
          "type": "string",
          "description": "ID pemilik bookmark"
        },
        "currentPage": {
          "type": "number",
          "description": "Halaman terakhir yang dibaca pengguna"
        },
        "totalPages": {
          "type": "number",
          "description": "Total halaman buku untuk kalkulasi persentase"
        }
      },
      "required": ["bookId", "progressStatus", "savedAt", "userId"]
    },
    "Notepad": {
      "title": "Notepad",
      "description": "Personal scroll book notes text",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "Content of notepad text notes"
        }
      },
      "required": ["text"]
    },
    "Review": {
      "title": "Review",
      "description": "Public review comment made by user for any book in catalogue",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID ulasan"
        },
        "reviewerName": {
          "type": "string",
          "description": "Nama pengulas"
        },
        "rating": {
          "type": "number",
          "description": "Nilai rating"
        },
        "comment": {
          "type": "string",
          "description": "Isi ulasan komentar"
        },
        "createdAt": {
          "type": "string",
          "description": "Tanggal pengiriman ulasan"
        },
        "bookId": {
          "type": "string",
          "description": "ID referensi buku"
        },
        "userId": {
          "type": "string",
          "description": "ID pengulas terautentikasi"
        }
      },
      "required": ["id", "reviewerName", "rating", "comment", "bookId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile collection doc"
    },
    "users/{userId}/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of custom books registered by user"
    },
    "users/{userId}/readingList/{bookId}": {
      "schema": "ReadingListItem",
      "description": "Bookmarks details containing list and and progress"
    },
    "users/{userId}/notes/notepad": {
      "schema": "Notepad",
      "description": "Individual single notepad page for personalized journaling"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collective feedback reviews feed for any specific book catalogue rating"
    }
  }
}
