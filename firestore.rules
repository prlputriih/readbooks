rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Dry Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Schema Validators
    
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'displayName'])
        && data.keys().size() <= 8
        && data.userId == request.auth.uid
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 150
        && (!('email' in data) || (data.email is string && data.email.size() <= 150))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50));
    }

    function isValidBook(data) {
      return data.keys().hasAll(['id', 'title', 'author', 'category'])
        && data.keys().size() <= 15
        && data.id is string
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.author is string
        && data.author.size() > 0
        && data.author.size() <= 200
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 100
        && (!('synopsis' in data) || (data.synopsis is string && data.synopsis.size() <= 10000))
        && (!('duration' in data) || (data.duration is string && data.duration.size() <= 100))
        && (!('pages' in data) || (data.pages is int && data.pages >= 0 && data.pages <= 50000))
        && (!('coverColor' in data) || (data.coverColor is string && data.coverColor.size() <= 150))
        && (!('buyUrl' in data) || (data.buyUrl is string && data.buyUrl.size() <= 2048))
        && (!('createdBy' in data) || (data.createdBy == request.auth.uid))
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    function isValidReadingListItem(data) {
      return data.keys().hasAll(['bookId', 'progressStatus', 'savedAt', 'userId'])
        && data.keys().size() <= 10
        && data.bookId is string
        && data.bookId.size() <= 128
        && data.progressStatus is string
        && data.progressStatus in ['ingin_dibaca', 'sedang_dibaca', 'selesai']
        && data.savedAt is string
        && data.savedAt.size() <= 50
        && data.userId == request.auth.uid
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000))
        && (!('currentPage' in data) || (data.currentPage is int && data.currentPage >= 0))
        && (!('totalPages' in data) || (data.totalPages is int && data.totalPages >= 0));
    }

    function isValidNotepad(data) {
      return data.keys().hasAll(['text'])
        && data.keys().size() <= 2
        && data.text is string
        && data.text.size() <= 100000;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'reviewerName', 'rating', 'comment', 'bookId', 'userId'])
        && data.keys().size() <= 10
        && data.id is string
        && data.id.size() <= 128
        && data.reviewerName is string
        && data.reviewerName.size() > 0
        && data.reviewerName.size() <= 150
        && (data.rating is int || data.rating is float)
        && data.rating >= 1
        && data.rating <= 5
        && data.comment is string
        && data.comment.size() > 0
        && data.comment.size() <= 5000
        && data.bookId is string
        && data.bookId.size() <= 128
        && data.userId == request.auth.uid
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    // 4. Matches routes

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());

      match /books/{bookId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidBook(incoming()) && isValidId(bookId);
      }

      match /readingList/{bookId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidReadingListItem(incoming()) && isValidId(bookId);
      }

      match /notes/{noteDoc} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidNotepad(incoming()) && isValidId(noteDoc);
      }
    }

    match /reviews/{reviewId} {
      // Reviews can be read by anyone, but queried with bookId filters
      allow get: if true;
      allow list: if resource.data.bookId != null;
      allow create: if isSignedIn() && isValidReview(incoming()) && isValidId(reviewId);
    }
  }
}
